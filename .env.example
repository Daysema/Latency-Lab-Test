# Домен сайта
# Локально (без TLS):  http://localhost
# Продакшен (авто TLS): latencylab.example.com
DOMAIN=http://localhost

# Email для Let's Encrypt (обязателен для реального домена)
ACME_EMAIL=admin@example.com

# Порт HTTP на хосте (8080 — для локальной разработки, 80 — для продакшена)
HTTP_PORT=8080
