# Домен сайта
# Локально (без TLS):  http://localhost  + docker-compose.override.yml (порт 8080)
# Продакшен (авто TLS): test.latencylab.ru  (без http://)
DOMAIN=test.latencylab.ru

# Email для Let's Encrypt (обязателен для реального домена)
ACME_EMAIL=admin@example.com

# ВАЖНО для HTTPS: порты 80 и 443 на сервере должны быть свободны и открыты в файрволе.
# Caddy всегда слушает 80/443 внутри контейнера — Let's Encrypt требует именно порт 80.
